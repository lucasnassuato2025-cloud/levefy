# =============================================================
# LEVEFY — Environment Variables
# Copy this file to .env.local for local development
# Set these in Render dashboard for production
# =============================================================

# --- SUPABASE (required) ---
# Get these from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- DATABASE — Neon PostgreSQL (required) ---
# Get from: https://console.neon.tech → your project → Connection string
# Use the "pooled" connection for DATABASE_URL (for queries)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1

# Use the "direct" connection for DIRECT_URL (for migrations only)
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# --- NEXT.JS ---
NEXTAUTH_URL=https://your-app.onrender.com
NODE_ENV=production
