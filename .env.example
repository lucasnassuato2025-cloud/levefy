# =============================================================
# LEVEFY — Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================

# --- SUPABASE (Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# --- DATABASE — Neon PostgreSQL ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host/db?sslmode=require

# --- NEXT ---
NEXTAUTH_URL=https://seu-dominio.com
NODE_ENV=production

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Crie os produtos no Stripe Dashboard:
# START: pagamento único R$27
STRIPE_PRICE_START=price_...
# PREMIUM: assinatura mensal R$19
STRIPE_PRICE_PREMIUM=price_...

# --- ADMIN ---
ADMIN_EMAIL=admin@seudominio.com

# --- TRACKING (opcional) ---
NEXT_PUBLIC_META_PIXEL_ID=seu_pixel_id
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_TIKTOK_PIXEL_ID=seu_pixel_tiktok
